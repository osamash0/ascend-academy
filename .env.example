# =============================================================================
# Learnstation — Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — REQUIRED
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

SUPABASE_URL=
SUPABASE_KEY=
# Alias for anon key (backend reads SUPABASE_ANON_KEY with fallback to SUPABASE_KEY)
SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (pgbouncer pooler)
DATABASE_URL=


# -----------------------------------------------------------------------------
# AI / LLM API Keys
# -----------------------------------------------------------------------------

GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional LLM providers for orchestrator fallback chain
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# Cloudflare Workers AI (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=


# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------

REDIS_PASSWORD=
REDIS_URL=
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

ALLOWED_ORIGINS=
# REQUIRED: set this to your production URL, e.g. https://yourdomain.com or http://<server-ip>:3000
CORS_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Frontend build-time vars
# -----------------------------------------------------------------------------

VITE_API_URL=
VITE_ANON_SALT=
VITE_AUTH_URL=
# Roadmap Phase 1.1 — SRS review engine dashboard tile/route. Off by default.
VITE_FEATURE_REVIEW_ENGINE=
# Roadmap Phase 3.1 — student self-serve uploads ("My Materials"). Off by default.
VITE_FEATURE_STUDENT_UPLOADS=
VITE_GROQ_API_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SENTRY_DSN=


# -----------------------------------------------------------------------------
# PDF Parser
# -----------------------------------------------------------------------------

# Parser pipeline version: 2 (default), 3, or 4
PARSER_VERSION=
PARSER_LLM_MODEL=
LLM_TIMEOUT_SECONDS=
VISION_MODEL=

MINERU_API_URL=
LLAMAPARSE_RESULT_TYPE=
LLAMA_CLOUD_API_KEY=


# -----------------------------------------------------------------------------
# Feature Flags & Optional Config
# -----------------------------------------------------------------------------

ENABLE_NUDGE_SCHEDULER=
NUDGE_RUN_SECRET=
NUDGE_RUN_HOUR_UTC=

ENVIRONMENT=
APP_ENV=

QUIZ_BATCH_SIZE=
QUIZ_BATCH_OVERLAP=


# -----------------------------------------------------------------------------
# Monitoring & Error Tracking
# -----------------------------------------------------------------------------

SENTRY_DSN=
