# =============================================================================
# Learnstation — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   docker compose up --build
#
# Variables marked REQUIRED must be set or the app will fail to start.
# Variables with a default are optional; the shown value is used if omitted.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — REQUIRED
# Get these from: Supabase dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Public project URL (e.g. https://abcxyz.supabase.co)
VITE_SUPABASE_URL=

# Anon / public key (safe to expose in the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Same URL used by the backend
SUPABASE_URL=

# Anon key used by the backend for RLS-enforced queries
SUPABASE_KEY=

# Alias for the anon key. backend/core/database.py reads SUPABASE_ANON_KEY and
# falls back to SUPABASE_KEY — set either one (same value as the anon key above).
SUPABASE_ANON_KEY=

# Service role key — grants full DB access; keep secret
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct asyncpg connection string (postgres://user:pass@host:5432/db)
# Found in Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=


# -----------------------------------------------------------------------------
# AI / LLM API Keys
# At least GROQ_API_KEY or GEMINI_API_KEY is needed for content generation.
# -----------------------------------------------------------------------------

# Groq inference (fast LLM): https://console.groq.com
GROQ_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google API fallback (used if GEMINI_API_KEY is unset)
GOOGLE_API_KEY=

# OpenAI — used by LiteLLM gateway and some services: https://platform.openai.com
OPENAI_API_KEY=

# Additional LLM providers used by the orchestrator fallback chain
# (backend/services/ai/orchestrator.py). All optional — set the ones you use.
# Cerebras is the orchestrator's primary fast provider: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# OpenRouter (multi-model gateway): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Mistral: https://console.mistral.ai
MISTRAL_API_KEY=

# Cloudflare Workers AI (optional LLM failover). Both required together.
# Token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
# Account ID: shown in the URL of any Cloudflare dashboard page
CLOUDFLARE_ACCOUNT_ID=


# -----------------------------------------------------------------------------
# Infrastructure (Docker defaults shown — change for external Redis/LiteLLM)
# -----------------------------------------------------------------------------

# Redis password for securing the job queue
REDIS_PASSWORD=

# Redis job queue broker
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# LiteLLM gateway
LITELLM_BASE_URL=http://litellm:4000

# Auth key for the LiteLLM gateway. Required in any networked deployment so the
# gateway rejects requests that don't present it (it routes your LLM provider
# keys). Generate with: sk-$(openssl rand -hex 32). Must start with "sk-".
LITELLM_MASTER_KEY=


# -----------------------------------------------------------------------------
# CORS — set when deploying to a non-localhost domain
# Comma-separated list of allowed origins for the backend.
# CORS_ALLOWED_ORIGINS takes precedence over ALLOWED_ORIGINS if both are set.
# In production set this to your real origin(s), e.g. https://your-uni-domain.edu
# -----------------------------------------------------------------------------

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173
CORS_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Frontend build-time vars (passed as Docker build ARGs)
# -----------------------------------------------------------------------------

# API base path — leave as /api to route through nginx proxy
VITE_API_URL=/api

# Salt for client-side analytics anonymization
VITE_ANON_SALT=learnstation-analytics-2026

# Optional feature flag: Set to "true" to load PDF pipeline components dynamically
VITE_LAZY_PDF_IMPORT=false


# -----------------------------------------------------------------------------
# PDF Parser
# -----------------------------------------------------------------------------

# Parser pipeline version: 2 (default), 3, 4, or 5 (unified: server-authoritative,
# vision-capable, persists lectures/slides/quizzes itself).
PARSER_VERSION=2

# Vision-capable model the unified pipeline (=5) uses for image/scanned/diagram
# slides, decoupled from the bulk text model. Must be vision-capable
# (gemini-2.0-flash or groq). Defaults to gemini-2.0-flash if unset.
VISION_MODEL=gemini-2.0-flash

# Bulk text model the unified pipeline (=5) uses for slide analysis + deck
# summary/quiz (server-configured, not chosen per upload). "cerebras" (free,
# fast) by default; set to "openai" to use OpenAI or a self-hosted
# OpenAI-compatible university LLM (see OPENAI_* below).
PARSER_LLM_MODEL=cerebras

# OpenAI-compatible LLM. OPENAI_API_KEY enables the "openai" provider. Point
# OPENAI_BASE_URL + OPENAI_MODEL at a self-hosted university LLM in prod (any
# OpenAI-compatible endpoint, e.g. vLLM) — no code change needed.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Hard timeout per LLM call (seconds, default 25). Raise for slower models:
# OpenAI gpt-4o-mini / self-hosted LLMs whose batch + deck calls exceed 25s.
# LLM_TIMEOUT_SECONDS=90

# MineRU OCR service URL (only needed if using MineRU)
MINERU_API_URL=http://localhost:8888

# LlamaIndex parse result format
LLAMAPARSE_RESULT_TYPE=markdown

# Model to use in LlamaParse (e.g. gpt-4o-mini, layoutv2). Defaults to gpt-4o-mini if omitted.
LLAMAPARSE_MODEL=gpt-4o-mini

# LlamaCloud / LlamaParse API key — only needed for PARSER_VERSION=3 or 4
# (backend/services/llamaparse_service.py). https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=


# -----------------------------------------------------------------------------
# Feature Flags & Optional Config
# -----------------------------------------------------------------------------

# Set to "1" to enable the daily nudge email scheduler
ENABLE_NUDGE_SCHEDULER=

# Secret token for the manual nudge trigger endpoint
NUDGE_RUN_SECRET=

# Hour (UTC) to run daily nudges (default: 13 = ~9 AM ET)
NUDGE_RUN_HOUR_UTC=13

# Environment label used in analytics events (e.g. production, staging, local)
ENVIRONMENT=local

# Deployment environment flag read by the backend (e.g. production, development)
APP_ENV=development

# Quiz processing batch config
QUIZ_BATCH_SIZE=8
QUIZ_BATCH_OVERLAP=1

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking
# -----------------------------------------------------------------------------

# Sentry DSN for frontend crash reporting
VITE_SENTRY_DSN=

# Sentry DSN for backend crash reporting
SENTRY_DSN=

# Sentry organization slug (used by backend admin dashboard to pull error issue reports)
SENTRY_ORG=

# Sentry project slug (used by backend admin dashboard to pull error issue reports)
SENTRY_PROJECT=

# Sentry integration API auth token with project:read permission
SENTRY_AUTH_TOKEN=
