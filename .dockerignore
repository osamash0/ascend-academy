# Version control
.git
.gitignore

# Frontend build output & deps
node_modules
dist
.vite

# Python virtual envs and cache
# NOTE: dockerignore patterns are root-relative — bare `venv` would only match
# ./venv, so nested trees (backend/venv, backend/__pycache__) need `**/`.
**/__pycache__
**/*.pyc
**/*.pyo
**/.venv
**/venv
mineru-env
**/*.egg-info
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Local env files (never copy secrets into image)
.env
.env.local
.env.*.local

# Dev/scratch artifacts
scratch/
.agent_scratch/
backend/scratch/
pdf_testset/
dump.rdb

# Other services (not needed in app image)
litellm/
Document-Insight-Engine/
mineru_server.py

# Test outputs
htmlcov/
.coverage
coverage/
coverage.xml
test-results/
e2e/

# Editor & OS
.DS_Store
*.swp
*.swo
.idea
.vscode
